    "fastify": "^4.28.0",
    "lru-cache": "^11.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
